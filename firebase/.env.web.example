# EtOH Coach — Firebase Web app config (client SDK only).
# Copy to firebase/.env.local and fill from Firebase Console → Project settings → Your apps → Web app.
# firebase/.env.local is gitignored — never commit real values.
#
# Used by Vite-based tools or local scripts that initialize the Firebase JS SDK.
# Server-side Rails sync uses a service account instead; see Etohcoach-Backend/docs/FIREBASE_RAILS_SYNC.md

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional:
# VITE_FIREBASE_MEASUREMENT_ID=
