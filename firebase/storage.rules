rules_version = '2';

/**
 * CMS media: admin-only writes. Reads are public for paths under etoh_cms/
 * so the consumer app can load images/video without Firebase Auth (JWT is on Rails).
 * Tighten to signed-URL-only later if product requires it.
 */
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /etoh_cms/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && (
          request.resource == null
          || (
            request.resource.size < 50 * 1024 * 1024
            && request.resource.contentType.matches('image/.*|video/.*|audio/.*|application/pdf')
          )
        );
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
