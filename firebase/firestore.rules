rules_version = '2';

/**
 * EtOH Coach CMS + published content reads.
 * M0: collections courses, lessons, flashcards, quiz_questions;
 * admin claim required for writes; non-admin read only where status/lesson_status is published.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /courses/{courseId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /flashcards/{flashcardId} {
      allow read: if resource.data.lesson_status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /quiz_questions/{questionId} {
      allow read: if resource.data.lesson_status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
