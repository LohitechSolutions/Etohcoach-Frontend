# Copy to firebase/etl/.env and load before migrate, or export vars in your shell.
#
# Rollback (parallel run): keep consumer app on REST — do not set EXPO_PUBLIC_CONTENT_SOURCE=firestore
# (or set CONTENT_SOURCE=rest in non-Expo bundles). See docs/MILESTONE_M3_IMPLEMENTATION.md.

# Railway / Rails API (no trailing slash)
RAILS_API_BASE_URL=https://etohcoach-backend-production.up.railway.app

# Same header the mobile app sends (JSON string in RestAPIRequestHeaderMessage)
RAILS_AUTH_TOKEN=

# Firebase Admin — either a path to a service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
# …or paste the full JSON (single line) for CI:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: import as draft (published otherwise)
ETL_IMPORT_AS_DRAFT=false

# Optional JSON map Rails theme id (string) → attract|convince|convert
# ETL_THEME_CATEGORY_JSON={"12":"attract","34":"convince"}
