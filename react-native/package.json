{
  "name": "etohcoach-nav-only-expo",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "postinstall": "node ./scripts/ensure-apple-shim-link.js && node ./scripts/patch-expo-dev-menu-simulator.js && node ./scripts/patch-rn-with-environment-spaces.js && node ./scripts/patch-expo-constants-app-config-script.js && node ./scripts/patch-ios-bundle-react-native-phase.js",
    "start": "node ./scripts/run-expo.cjs start",
    "start:clear": "node ./scripts/run-expo.cjs start --clear",
    "android": "node ./scripts/run-expo.cjs run:android",
    "ios": "node ./scripts/run-expo.cjs run:ios",
    "web": "node ./scripts/run-expo.cjs start --web",
    "typecheck": "tsc --noEmit",
    "prebuild:android": "CI=1 npx expo prebuild --platform android --no-install",
    "build:apk": "cd android && ./gradlew assembleDebug",
    "build:apk:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.3",
    "@invertase/react-native-apple-authentication": "file:./src/shims/npm/@invertase/react-native-apple-authentication",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/checkbox": "^0.5.20",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.39",
    "expo-dev-client": "~4.0.29",
    "expo-status-bar": "~1.12.1",
    "firebase": "^11.6.0",
    "i18n-js": "^3.9.2",
    "metro": "~0.80.8",
    "moment": "^2.29.4",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-elements": "^3.4.0",
    "react-native-fbsdk": "file:./src/shims/npm/react-native-fbsdk",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-modal-activityindicator": "0.0.1",
    "react-native-paper": "^5.15.1",
    "react-native-purchases": "^10.0.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-swiper": "^1.6.0",
    "react-native-uuid": "^2.0.1",
    "react-native-webview": "13.8.6",
    "react-navigation": "2.18.1",
    "url": "^0.11.4",
    "url-parse": "^1.5.10",
    "uuid": "^8.3.2",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.2.79",
    "typescript": "^5.5.4"
  }
}
