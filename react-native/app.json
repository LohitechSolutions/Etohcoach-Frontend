{
  "expo": {
    "name": "EtOHCoach",
    "slug": "etohcoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.etohcoach"
    },
    "android": {
      "package": "com.yourcompany.etohcoach"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [],
    "extra": {
      "migration": {
        "defaultUi": "packages/mobile (legacy)",
        "newShellOptIn": "Set EXPO_PUBLIC_USE_EXPO_SHELL=true for AppNavigator scaffold."
      }
    }
  }
}
