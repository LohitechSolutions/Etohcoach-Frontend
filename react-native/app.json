{
  "expo": {
    "name": "EtOHCoach",
    "slug": "etohcoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.etohcoach"
    },
    "android": {
      "package": "com.yourcompany.etohcoach",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [],
    "extra": {
      "migration": {
        "defaultUi": "AppShell (RN6 + legacy blocks)",
        "legacyV2OptIn": "EXPO_PUBLIC_USE_LEGACY_APP=true for packages/mobile/App.",
        "apiNote": "Expo API: react-native/src/config/expoFrameworkConfig.js (Railway default). Metro replaces packages/framework/src/config. Optional react-native/.env EXPO_PUBLIC_API_URL for local Rails."
      }
    }
  }
}
