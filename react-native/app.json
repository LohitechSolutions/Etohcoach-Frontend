{
  "expo": {
    "name": "EtOHCoach",
    "slug": "etohcoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.etohcoach"
    },
    "android": {
      "package": "com.yourcompany.etohcoach"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [],
    "extra": {
      "migration": {
        "defaultUi": "AppShell (RN6 + legacy blocks)",
        "legacyV2OptIn": "EXPO_PUBLIC_USE_LEGACY_APP=true for packages/mobile/App.",
        "offlineApiClient": "EXPO_PUBLIC_OFFLINE_MODE=false for real HTTP in src/services/api only; blocks use framework APIs."
      }
    }
  }
}
