# Optional — only if you run Etohcoach-Backend on your machine.
# Without EXPO_PUBLIC_API_URL, the Expo app uses react-native/src/config/expoFrameworkConfig.js (Railway).
#
# Copy to `react-native/.env` and uncomment ONE line:
#
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
#
# Physical device (same Wi‑Fi as your Mac): use your computer's LAN IP, e.g.
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# Android emulator alternative:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
