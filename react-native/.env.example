# Copy to `react-native/.env` and uncomment what you need. Expo inlines EXPO_PUBLIC_* at bundle time.
#
# Render (hosted API):
# EXPO_PUBLIC_API_URL=https://your-service.onrender.com
#
# Railway (default if EXPO_PUBLIC_API_URL is unset — see react-native/src/config/expoFrameworkConfig.js):
# EXPO_PUBLIC_API_URL=https://etohcoach-backend-production.up.railway.app
#
# Local Rails:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
#
# Physical device + Mac on same Wi‑Fi:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
#
# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
